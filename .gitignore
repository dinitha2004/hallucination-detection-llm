# ============================================================
# .gitignore — Hallucination Detection System
# ============================================================

# ── Python ───────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg
*.egg-info/
dist/
build/
.eggs/

# ── Virtual Environments ─────────────────────────────────────
venv/
env/
ENV/
.venv/

# ── Environment Variables (NEVER commit secrets) ─────────────
.env
.env.local
.env.production

# ── Model Weights (too large for GitHub) ─────────────────────
model_weights/
*.bin
*.safetensors
*.pt
*.pth

# ── HuggingFace Cache ─────────────────────────────────────────
.cache/
~/.cache/huggingface/

# ── MLflow ───────────────────────────────────────────────────
mlruns/
mlartifacts/

# ── Jupyter Notebooks checkpoints ────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints

# ── Node / React ─────────────────────────────────────────────
node_modules/
frontend/build/
frontend/dist/
npm-debug.log*
yarn-debug.log*

# ── OS Files ─────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db

# ── IDE ───────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── Data (keep structure, ignore large raw files) ────────────
data/truthfulqa/*.json
data/triviaqa/*.json
data/memory_bank/*.npy

# ── Test & Coverage ───────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/

# ── Logs ─────────────────────────────────────────────────────
*.log
logs/
frontend/.vite/
