# ============================================================
# .env.example — Copy this file to .env and fill in your values
# NEVER commit your .env file to GitHub
# ============================================================

# ── LLM Model Configuration ──────────────────────────────────
# Primary model (requires HuggingFace access approval)
MODEL_NAME=facebook/opt-1.3b

# Fallback model (no approval needed — use this while waiting for LLaMA)
# MODEL_NAME=facebook/opt-1.3b

# Your HuggingFace token (get from https://huggingface.co/settings/tokens)
HF_TOKEN=your_huggingface_token_here

# ── Detection Configuration ───────────────────────────────────
# Hallucination threshold (0.0 = flag nothing, 1.0 = flag everything)
HALLUCINATION_THRESHOLD=0.65

# Layers to extract hidden states from (comma-separated indices)
TARGET_LAYERS=16,20,24

# Feature clipping percentile for INSIDE mechanism
FEATURE_CLIP_PERCENTILE=95

# ── Server Configuration ──────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# ── Frontend Configuration ────────────────────────────────────
REACT_APP_API_URL=http://localhost:8000

# ── MLflow Configuration ──────────────────────────────────────
MLFLOW_TRACKING_URI=./mlruns
EXPERIMENT_NAME=hallucination_detection_v1

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_PROMPTS=false
